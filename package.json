{
  "name": "opencue",
  "version": "0.0.1",
  "description": "Open-source meeting copilot desktop app: real-time transcription, AI assistance, and an always-on-top overlay excluded from screen sharing. Bring your own keys or run fully local.",
  "author": {
    "name": "mudassar531",
    "url": "https://github.com/mudassar531"
  },
  "license": "MIT",
  "homepage": "https://github.com/mudassar531/opencue",
  "repository": {
    "type": "git",
    "url": "https://github.com/mudassar531/opencue.git"
  },
  "bugs": {
    "url": "https://github.com/mudassar531/opencue/issues"
  },
  "keywords": [
    "electron",
    "meeting-copilot",
    "transcription",
    "ai-assistant",
    "overlay",
    "whisper",
    "deepgram",
    "openai",
    "anthropic",
    "ollama",
    "open-source",
    "cluely-alternative"
  ],
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"docs/**/*.md\" \"*.{js,cjs,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"docs/**/*.md\" \"*.{js,cjs,mjs,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "postinstall": "echo \"opencue: postinstall ok\""
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.24",
    "electron-store": "^10.0.1",
    "onnxruntime-web": "^1.26.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vite-plugin-static-copy": "^2.3.2",
    "vitest": "^2.1.8"
  }
}
