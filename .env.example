# opencue — example environment file.
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# At runtime, API keys are entered through Settings and encrypted via Electron safeStorage.
# These env vars are only used for development/testing convenience.

# --- Cloud STT ---
# OPENCUE_OPENAI_API_KEY=
# OPENCUE_DEEPGRAM_API_KEY=
# OPENCUE_ASSEMBLYAI_API_KEY=

# --- Cloud LLM ---
# OPENCUE_ANTHROPIC_API_KEY=
# OPENCUE_GOOGLE_API_KEY=
# OPENCUE_GROQ_API_KEY=

# --- Cloud TTS ---
# OPENCUE_ELEVENLABS_API_KEY=
# OPENCUE_CARTESIA_API_KEY=

# --- Local LLM (Ollama) ---
# OPENCUE_OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Dev only ---
# OPENCUE_LOG_LEVEL=debug
